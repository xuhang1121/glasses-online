.ar-wrap {
  width: 100vw;
  height: 100vh;
  background: #111827;
}

.xr-scene {
  width: 100vw;
  height: 100vh;
}

.ar-status {
  position: fixed;
  left: 50%;
  top: calc(32rpx + env(safe-area-inset-top));
  transform: translateX(-50%);
  min-width: 260rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 8rpx;
  background: rgba(17, 24, 39, 0.72);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
}

.ar-status.active {
  background: rgba(8, 116, 67, 0.82);
}
