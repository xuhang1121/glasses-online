<view class="ar-page" wx:if="{{product}}">
  <ar-glasses
    product-name="{{product.name}}"
    model-url="{{product.modelUrl}}"
    model-scale="{{product.modelScale}}"
    model-position="{{product.modelPosition}}"
    model-rotation="{{product.modelRotation}}"
  />

  <view class="ar-bottom">
    <view class="product-row">
      <image src="{{product.fullCoverUrl}}" mode="aspectFit" />
      <view>
        <view class="product-name">{{product.name}}</view>
        <view class="product-meta">{{product.frameWidthMm}}mm · {{product.color}}</view>
      </view>
    </view>
    <button class="primary-button" bindtap="addCart">加入购物车</button>
  </view>
</view>

<view wx:else class="loading-page">
  <view>加载 AR 试戴中...</view>
</view>
