<view class="page">
  <view class="section-title">购物车</view>

  <view wx:if="{{!items.length}}" class="empty">还没有加入商品</view>

  <view wx:else class="cart-list">
    <view wx:for="{{items}}" wx:key="id" class="cart-item">
      <view>
        <view class="cart-name">{{item.name}}</view>
        <view class="muted">{{item.frameWidthMm}}mm · 数量 {{item.quantity}}</view>
      </view>
      <view class="cart-price">{{item.subtotalText}}</view>
    </view>
  </view>

  <view class="checkout-bar">
    <view>
      <view class="muted">合计</view>
      <view class="total">{{totalText}}</view>
    </view>
    <button class="primary-button checkout" bindtap="checkout">去结算</button>
  </view>
</view>

