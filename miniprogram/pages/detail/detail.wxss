.hero-image {
  width: 100%;
  height: 360rpx;
  background: #ffffff;
  border-radius: 8rpx;
  border: 1rpx solid #eaecf0;
}

.detail-main {
  margin-top: 24rpx;
}

.name-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  align-items: flex-start;
}

.product-name {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.price {
  color: #b42318;
  font-size: 36rpx;
  font-weight: 800;
  white-space: nowrap;
}

.spec-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.spec-item {
  min-height: 128rpx;
  border-radius: 8rpx;
  border: 1rpx solid #eaecf0;
  background: #ffffff;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 0 24rpx;
}

.spec-value {
  font-size: 34rpx;
  font-weight: 800;
}

.spec-label {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: grid;
  grid-template-columns: 1fr 1fr 1.15fr;
  gap: 16rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid #eaecf0;
}

.page {
  padding-bottom: 140rpx;
}

.empty {
  padding: 80rpx 0;
  text-align: center;
  color: #667085;
}
