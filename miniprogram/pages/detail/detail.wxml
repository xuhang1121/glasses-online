<view class="page" wx:if="{{product}}">
  <image class="hero-image" src="{{product.fullCoverUrl}}" mode="aspectFit" />

  <view class="detail-main">
    <view class="name-row">
      <view>
        <view class="product-name">{{product.name}}</view>
        <view class="muted">{{product.material}} · {{product.color}}</view>
      </view>
      <view class="price">{{product.priceText}}</view>
    </view>

    <view class="section-title">尺寸参数</view>
    <view class="spec-grid">
      <view class="spec-item">
        <text class="spec-value">{{product.frameWidthMm}}mm</text>
        <text class="spec-label">镜架宽度</text>
      </view>
      <view class="spec-item">
        <text class="spec-value">{{product.lensWidthMm}}mm</text>
        <text class="spec-label">单片宽</text>
      </view>
      <view class="spec-item">
        <text class="spec-value">{{product.bridgeWidthMm}}mm</text>
        <text class="spec-label">鼻梁宽</text>
      </view>
      <view class="spec-item">
        <text class="spec-value">{{product.templeLengthMm}}mm</text>
        <text class="spec-label">镜腿长</text>
      </view>
    </view>
  </view>

  <view class="action-bar">
    <button class="ghost-button" bindtap="addCart">加入购物车</button>
    <button class="ghost-button" bindtap="startTryOn">照片试戴</button>
    <button class="primary-button" bindtap="startArTryOn">AR 试戴</button>
  </view>
</view>

<view wx:else class="page">
  <view class="empty">加载详情中...</view>
</view>
