page {
  min-height: 100vh;
  background: #f5f7fb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Arial, sans-serif;
}

.page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 24rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
  margin: 8rpx 0 20rpx;
}

.muted {
  color: #667085;
}

.primary-button {
  height: 88rpx;
  border-radius: 8rpx;
  background: #111827;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.ghost-button {
  height: 84rpx;
  border-radius: 8rpx;
  border: 1rpx solid #d0d5dd;
  color: #111827;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  background: #ffffff;
}

